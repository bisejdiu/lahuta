from enum import Enum
from time import perf_counter
from typing import Any, Callable, Dict, List, Literal, Optional, Tuple

import numpy as np
import pandas as pd
from rich import print
from rich.console import Console
from rich.table import Table
from typer import Argument, Option, Typer
from typer.core import TyperGroup
from typing_extensions import Annotated

from lahuta import Luni
from lahuta.contacts import F
from lahuta.core import NeighborPairs


# pylint: disable=redefined-builtin
class PrettyDataFrame:
    INT_COLOR = "red"
    FLOAT_COLOR = "green"
    OTHER_COLOR = "blue"

    def __init__(self, df: pd.DataFrame, n_rows: int = 20):
        self.total_rows = len(df)
        self.n_rows = n_rows if n_rows < self.total_rows else self.total_rows
        self.df = df.reset_index().rename(columns={"index": ""}).head(self.n_rows)
        self.console = Console()
        self.table = Table(show_footer=False)

    def _add_columns(self) -> None:
        for col in self.df.columns:
            self.table.add_column(str(col))

    def _add_rows(self) -> None:
        for row in self.df.values:
            formatted_row = self._format_row(row)
            self.table.add_row(*formatted_row)
        if self.n_rows < self.total_rows:
            self.table.add_row(*["..." for _ in range(len(self.df.columns))])

    def _format_row(self, row: List[Any]) -> List[str]:
        formatted_row = []
        for index, item in enumerate(row):
            # Index without color change
            if index == 0:
                formatted_row.append(str(item))
                continue

            if isinstance(item, int):
                formatted_row.append(f"[{self.INT_COLOR}]{item}[/{self.INT_COLOR}]")
            elif isinstance(item, float):
                formatted_row.append(f"[{self.FLOAT_COLOR}]{item}[/{self.FLOAT_COLOR}]")
            else:
                formatted_row.append(f"[{self.OTHER_COLOR}]{item}[/{self.OTHER_COLOR}]")

        return formatted_row

    def _add_caption(self) -> None:
        self.table.caption = f"Showing {self.n_rows} rows out of {self.total_rows} computed rows"

    def prettify(self) -> None:
        """
        Prettify the dataframe and print it to the console.
        """
        self._add_columns()
        self._add_rows()
        self._add_caption()
        self.console.print(self.table)


class ContactGroup(str, Enum):
    all = "all"
    hydrophobic = "hydrophobic"
    atom_atom = "atom-atom"


class ExportGroup(str, Enum):
    screen = "screen"
    csv = "csv"

class FormatGroup(str, Enum):
    compact = "compact"
    expanded = "expanded"

lahuta = Typer(
    help="[blue]Lahuta CLI.[/blue] :sparkles:",
    rich_markup_mode="rich",
    add_completion=False,
    context_settings={"help_option_names": ["-h", "--help"]},
    # no_args_is_help=True,
)

# app = Typer()

CONTACT_FUNCTIONS: Dict[str, Callable[[NeighborPairs], NeighborPairs]] = {
    "carb": F.carbonyl_neighbors,
    "hb": F.hbond_neighbors,
    "ionic": F.ionic_neighbors,
    "aromatic": F.aromatic_neighbors,
    "hydrophobic": F.hydrophobic_neighbors,
    "vdw": F.vdw_neighbors,
}

CONTACT_GROUP_MAPPING = {
    ContactGroup.all: CONTACT_FUNCTIONS.keys(),
    ContactGroup.hydrophobic: ["hydrophobic", "vdw"],
    ContactGroup.atom_atom: ["carb", "hb", "ionic", "aromatic", "hydrophobic", "vdw"],
}

RESIDUE_DIFF_DEFAULT = 2


def compute_contacts(ns: NeighborPairs, contact_group: ContactGroup):
    contact_results: Dict[str, NeighborPairs] = {}
    for contact_type in CONTACT_GROUP_MAPPING[contact_group]:
        func = CONTACT_FUNCTIONS[contact_type]
        func_result = func(ns)
        contact_results[contact_type] = func_result
        # df = func_result.to_frame(df_format='compact')
        # df['distances'] = df['distances'].round(4)
        # pretty_df = PrettyDataFrame(df)
        # pretty_df.prettify()

    return contact_results


def compute_neighbors(file_name: str, radius: float, res_dif: int) -> NeighborPairs:
    luni = Luni(file_name)
    ns = luni.compute_neighbors(radius=radius, res_dif=res_dif)
    return ns


@lahuta.command(
    epilog="[blue]Cheers![/blue]",
)
def run(
    input: str = Option(..., "--input", "-i", help="Input file name for Luni"),
    radius: Annotated[
        float, Option(..., "--radius", "-r", show_default=True, help="Radius for neighbor computation.")
    ] = 5.0,
    res_dif: Annotated[
        int, Option(..., "--res_dif", "-d", show_default=True, help="Residue difference for neighbor computation.")
    ] = RESIDUE_DIFF_DEFAULT,
    contact_group: ContactGroup = Option(
        'all',
        "--contact-group",
        "-cg",
        help="Contact group to compute.",
    ),
    export: List[ExportGroup] = Option(
        ['screen'],
        "--export",
        "-to",
        help="How to output results.",
    ),
    # export: Annotated[List[str], Option(..., "--export", "-to", help="How to output results")] = ["screen"],
    n_rows: int = Option(20, "--n-rows", "-n", help="Number of rows to display."),
    format: FormatGroup = Option(
        'compact',
        "--format",
        "-f",
        help="Format of the output.",
    ),

) -> None:
    """
    [blue][bold red]WELCOME TO LAHUTA[/bold red][/blue] :sparkles:
    (v0.9.0)

    -----------------------------

    Authors: Besian I. Sejdiu
    Developed with ❤️ by St. Jude Children's Research Hospital
    Learn more by reading the [link=https://github.com/bisejdiu/lahuta]docs[/link]!

    ---
    Lahuta is a modern computational tool designed to calculate atom-atom interactions with high performance, scalability, and extensibility.
    Building on first principles, it provides an intuitive and user-friendly interface that simplifies complex computations,
    delivering reliable results quickly and efficiently.

    While Lahuta is intended to be primarily used through its API, the following script/CLI is provided as a convenience for very common operations.

    Should you encounter a bug or want to request a feature, please don't hesitate to open an issue at github.com/bisejdiu/lahuta.

    """
    start = perf_counter()
    ns = compute_neighbors(input, radius=radius, res_dif=res_dif)

    results = compute_contacts(ns, contact_group)
    print ('format', format)

    for export_type in export:
        print(export_type)
        if export_type == ExportGroup.screen:
            print('Printing to screen')
            collect_dfs = None
            total_rows = 0
            while total_rows < n_rows:
                for contact_type, result in results.items():
                    print ('Contact type', contact_type)
                    total_rows += result.pairs.shape[0]
                    if total_rows > n_rows:
                        new_result = result.clone(result.pairs[:n_rows], result.distances[:n_rows])
                        new_result.add_annotations({
                            'contact_type': np.array([contact_type] * new_result.pairs.shape[0])
                        })
                        df = new_result.to_frame(df_format=format.value, annotations=True)
                        df['distances'] = df['distances'].round(4)
                        if collect_dfs is None:
                            collect_dfs = df
                        else:
                            collect_dfs = pd.concat([collect_dfs, df])
                        break
                    else:
                        result.add_annotations({
                            'contact_type': np.array([contact_type] * result.pairs.shape[0])
                        })
                        df = result.to_frame(df_format=format.value, annotations=True)
                        df['distances'] = df['distances'].round(4)
                        if collect_dfs is None:
                            collect_dfs = df
                        else:
                            collect_dfs = pd.concat([collect_dfs, df])
                        total_rows += result.pairs.shape[0]

            assert collect_dfs is not None
            pretty_df = PrettyDataFrame(collect_dfs)
            pretty_df.prettify()


        elif export_type == ExportGroup.csv:
            print('Printing to csv')

    end = perf_counter()
    print()
    print(f"Done in: {end - start:.5f} seconds.")


if __name__ == "__main__":
    lahuta()
